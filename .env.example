# Generate a secret key with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change_me_to_a_long_random_secret

# Set to true only for local development; defaults to false for safety
DEBUG=false

USE_POSTGRES=true
POSTGRES_DB=bytehub
POSTGRES_USER=bytehub_user
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_CONN_MAX_AGE=60
